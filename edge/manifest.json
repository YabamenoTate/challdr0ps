{
  "manifest_version": 3,
  "name": "__MSG_ext_name__",
  "version": "1.0",
  "default_locale": "ja",
  "description": "__MSG_ext_description__",
  "icons": {
    "16": "common/icon/challdr0ps_16.png",
    "48": "common/icon/challdr0ps_48.png",
    "128": "common/icon/challdr0ps_128.png"
  },
  "permissions": [
    "storage",
    "downloads",
    "clipboardRead",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://challdr0ps.omg-vert.eu.org/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://manaba.meisei-u.ac.jp/*"
      ],
      "js": [
        "common/copylms.js"
      ],
      "css": [
        "common/copylms.css"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "common/icon/*.webp",
        "common/icon/*.svg"
      ],
      "matches": [
        "https://manaba.meisei-u.ac.jp/*"
      ]
    }
  ]
}